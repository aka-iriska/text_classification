        "id": "ae3f718f0b875974"
      },
      "cell_type": "code",
      "source": [
        "def tokenize_function(examples):\n",
        "    # Склеиваем url и title, как делали раньше\n",
        "    texts = [f\"{t} {u}\" for t, u in zip(examples[\"title\"], examples[\"url\"])]\n",
        "    return tokenizer(texts, padding=\"max_length\", truncation=True, max_length=128)"
      ],
      "id": "ae3f718f0b875974",
      "outputs": [],
      "execution_count": 58
    },
    {
