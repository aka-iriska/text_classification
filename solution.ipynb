    },
    {
      "metadata": {
        "ExecuteTime": {
          "end_time": "2026-04-17T14:13:30.948930800Z",
          "start_time": "2026-04-17T14:13:30.163293800Z"
        },
        "id": "7cafd262b62e66be"
      },
      "cell_type": "code",
      "source": [
        "X_train_url = vectorizer_url.fit_transform(train_url_clean)\n",
