      "source": [
        "### Обучение"
      ],
      "id": "eb26ae7b2fecd8d9"
    },
    {
      "metadata": {
        "ExecuteTime": {
          "end_time": "2026-04-17T14:13:36.175062Z",
          "start_time": "2026-04-17T14:13:36.044780900Z"
        },
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "1bc0d2ba7480531c",
        "outputId": "13f794ae-ae3e-42c3-d474-06b715945dea"
      },
      "cell_type": "code",
      "source": [
        "all_feature_names = list(vectorizer_url.get_feature_names_out()) + list(vectorizer_title.get_feature_names_out())\n",
        "\n",
        "row = X_train_combined[0]\n",
        "\n",
        "word_values = [\n",
        "    (all_feature_names[i], row.data[idx])\n",
        "    for idx, i in enumerate(row.indices)\n",
        "]\n",
        "\n",
        "word_values.sort(key=lambda x: x[1], reverse=True)\n",
        "\n",
        "for word, score in word_values:\n",
        "    print(f\"Слово: {word:20} | Вес TF-IDF: {score:.4f}\")"
      ],
      "id": "1bc0d2ba7480531c",
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
