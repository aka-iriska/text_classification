      "source": [
        "Склеиваем (hstack) матрицы признаков по горизонтали"
      ],
      "id": "6d04ef62e1deca76"
    },
    {
      "metadata": {
        "ExecuteTime": {
          "end_time": "2026-04-17T14:13:36.044780900Z",
          "start_time": "2026-04-17T14:13:36.003098300Z"
        },
        "id": "96dcccd72033d941"
      },
      "cell_type": "code",
      "source": [
        "from scipy.sparse import hstack\n",
        "\n",
        "X_train_combined = hstack([X_train_url, X_train_title])\n",
        "X_test_combined  = hstack([X_test_url, X_test_title])"
      ],
      "id": "96dcccd72033d941",
      "outputs": [],
      "execution_count": 16
    },
