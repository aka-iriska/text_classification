    },
    {
      "cell_type": "markdown",
      "source": [
        "Снова выделим из обучающей выборки валидационную:"
      ],
      "metadata": {
        "id": "aDOziTluem-L"
      },
      "id": "aDOziTluem-L"
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "train_sub, val_sub = train_test_split(\n",
        "    train_df,\n",
        "    test_size=0.2,\n",
        "    random_state=42,\n",
        "    stratify=train_df['label']\n",
        ")"
      ],
      "metadata": {
