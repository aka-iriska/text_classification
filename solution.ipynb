      "cell_type": "markdown",
      "source": [
        "Создаем два отдельных векторизатора для `url` и для `title`"
      ],
      "id": "e01529b6d3f9114f"
    },
    {
      "metadata": {
        "ExecuteTime": {
          "end_time": "2026-04-17T14:13:30.160526800Z",
          "start_time": "2026-04-17T14:13:30.144363300Z"
        },
        "id": "e533701119fff05b"
      },
      "cell_type": "code",
      "source": [
        "from sklearn.feature_extraction.text import TfidfVectorizer\n",
        "\n",
        "vectorizer_url = TfidfVectorizer(max_features=50000)\n",
        "vectorizer_title = TfidfVectorizer(max_features=100000, ngram_range=(1, 2))"
      ],
      "id": "e533701119fff05b",
      "outputs": [],
      "execution_count": 12
    },
    {
      "metadata": {
